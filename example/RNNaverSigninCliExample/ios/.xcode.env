# This `.xcode.env` file is versioned and is used to source the environment
# used when running script phases inside Xcode.
# To customize your local environment, you can create an `.xcode.env.local`
# file that is not versioned.

# NODE_BINARY variable contains the PATH to the node executable.
#
# Xcode can pick up a different PATH than the interactive shell, so prefer the
# first working Node binary instead of trusting `command -v node` blindly.
for candidate in \
  "${NODE_BINARY:-}" \
  "$(command -v node 2>/dev/null)" \
  "/Applications/Codex.app/Contents/Resources/node" \
  "/opt/homebrew/bin/node"
do
  if [ -n "$candidate" ] && [ -x "$candidate" ] && "$candidate" -v >/dev/null 2>&1; then
    export NODE_BINARY="$candidate"
    break
  fi
done

if [ -z "${NODE_BINARY:-}" ]; then
  echo "error: Unable to find a working node binary for Xcode build scripts." >&2
  exit 1
fi
